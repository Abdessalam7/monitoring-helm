  --namespace=monitoring-datahub-v2 \
  --from-literal=COS_ENDPOINT="https://s3.direct.eu-fr2.cloud-object-storage.appdomain.cloud" \
  --from-literal=COS_API_KEY="6a076103f74721a960ce98249208b15eb637ccf13db7e966" \
  --from-literal=COS_INSTANCE_CRN="<crn>" \
  --from-literal=COS_BUCKET="<bucket>"
